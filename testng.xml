<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<!--
    testng.xml - Master TestNG Suite Configuration
    Framework: Hybrid BDD Automation (Selenium + RestAssured + Cucumber + TestNG)

    Parameters override via Maven: -Dbrowser=chrome -Denv=qa -Dtags=@Smoke
-->
<suite name="Hybrid Automation Suite"
       verbose="1"
       thread-count="2"
       parallel="methods"
       data-provider-thread-count="2">

    <!-- Global Listeners -->
    <listeners>
        <listener class-name="com.framework.listeners.TestListener"/>
        <listener class-name="com.framework.listeners.RetryTransformer"/>
    </listeners>

    <!-- ═══════════════════════════════════════════════════
         SMOKE TESTS - Fast feedback (UI + API)
    ═══════════════════════════════════════════════════ -->
    <test name="Smoke Tests" preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <classes>
            <class name="com.framework.runners.SmokeRunner"/>
        </classes>
    </test>

    <!-- ═══════════════════════════════════════════════════
         API TESTS - PetStore REST API
    ═══════════════════════════════════════════════════ -->
    <test name="API Regression Tests" preserve-order="true">
        <classes>
            <class name="com.framework.runners.RegressionRunner"/>
        </classes>
    </test>

</suite>
